# Rust
target/
**/*.rs.bk
Cargo.lock.bak

# Lockfiles - keep
# (Cargo.lock IS committed for binaries; this workspace has bins so we keep it)

# IDE / editors
.vscode/
.idea/
*.swp
*.swo
.DS_Store

# Apple build outputs
apple/build/
apple/DerivedData/
apple/*.xcodeproj/
apple/*.xcworkspace/
*.xcframework/
# Fallback DerivedData location if Xcode is invoked outside `make app`
# (Makefile pins DerivedData to apple/build/, but Xcode.app defaults to a
# root-level build/ when opened directly).
/build/
DerivedData/
# UniFFI-generated Swift bindings — regenerated by scripts/build-xcframework.sh
apple/DubShared/Sources/DubCore/Generated/
# Swift Package Manager build state inside the package
apple/DubShared/.build/
apple/DubShared/.swiftpm/
apple/DubShared/Package.resolved

# Test / coverage outputs
coverage/
*.profraw
*.profdata
target/llvm-cov-target/

# Fuzz outputs
fuzz/target/
fuzz/corpus/
fuzz/artifacts/

# Local logs / dumps
*.log
crashes/

# Env / secrets
.env
.env.local
*.pem
*.code-workspace

# Apple developer artifacts
ExportOptions.plist
*.p12
